# selfmatrix-hires 接続設定 (launcher/connect.sh, connect.ps1 が読み込みます)
#
# 運用者はこのファイルをコピーして値を埋め、参加者に配布してください。
#   cp hires.conf.example hires.conf
# 配布時のファイル名は "hires.conf" のままにしておくと、connect.sh /
# connect.ps1 が引数なしで自動的にこのファイルを読みます (スクリプトと同じ
# ディレクトリを見ます)。
#
# 書式: key=value (1行1キー)。# で始まる行と空行はコメントとして無視されます。
# value を "" や '' で囲む必要はありません (空白を含む値は §AUDIO_DEVICE 参照)。
# 逆に引用符で囲むと、引用符そのものが値の一部として扱われて接続に失敗する
# ため、囲まないでください (例: HOST="example.com" は NG)。

# HOST (必須): 接続先ホスト名。運用者から案内された、CDN を経由しない
# DNS-only のホスト名を指定してください (README.md §3.1 参照)。
HOST=

# SAMPLE_RATE (既定 192000): サンプルレート(Hz)。hub 側と一致させる必要が
# あります。192kHz 非対応の参加者が混ざる回は、運用者の案内に従って
# 48000 に変更してください。
SAMPLE_RATE=192000

# BIT_RES (既定 24): ビット深度。hub 側と一致していないと即切断されます。
# 運用者から別途案内が無い限り変更しないでください。
BIT_RES=24

# CHANNELS (既定 2): チャンネル数 (2 = ステレオ)。
CHANNELS=2

# QUEUE (既定 8): ジッタバッファのキューサイズ (jacktrip -q)。音が途切れる
# 場合は運用者の案内に従って増やしてください (レイテンシは若干増えます)。
QUEUE=8

# USERNAME (必須): 運用者から発行されたあなたのユーザー名。
USERNAME=

# PASSWORD (任意、推奨は空欄): 運用者から発行されたパスワード。
# ここに書くとこのファイルの読み取り権限を持つ人・プロセスに見える形で
# 保存されることになります。また `ps` 等のプロセス一覧コマンドは実行中の
# jacktrip プロセスのコマンドライン引数を他ユーザーから見える形で表示する
# 場合があります(これは jacktrip 自体に内在する制約で、このランチャーでは
# 回避できません)。共有 PC や複数ユーザーのマシンで使う場合は、この項目を
# 空欄のままにし、jacktrip の対話プロンプト(画面には表示されない入力)で
# 都度入力することを推奨します。
PASSWORD=

# AUDIO_DEVICE (任意): 使用するオーディオデバイス名 (jacktrip --audiodevice)。
# 空欄なら OS既定のデバイスを使います。デバイス名一覧は `jacktrip
# --listdevices` で確認できます。名前に空白が含まれる場合もそのまま
# 書いてください(スクリプト側で正しくクォートします)。
# 例: AUDIO_DEVICE=Focusrite USB Audio
AUDIO_DEVICE=

# EXTRA_ARGS (任意): 上記でカバーされない追加の jacktrip 引数をそのまま
# 渡したい場合に使います。この値は単語分割(スペース区切り)されてから
# jacktrip に渡されます。空白を含む1つの値を渡したい場合は、この仕組みの
# 都合上うまく扱えないため、運用者に相談してスクリプトの調整を依頼して
# ください。
# 例: EXTRA_ARGS=--peer-timeout 5000
EXTRA_ARGS=
